# NLPTrader Environment Variables
# Copy to .env and fill in your keys

# PostgreSQL (adjust if using different credentials)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nlptrader

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chromadb

# Finnhub API Key (required for news)
# Get from: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# LLM Provider - Groq (free tier available)
# Get from: https://console.groq.com
LLM_API_KEY=your_groq_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# LLM Fallback - Google Gemini (free tier)
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Optional: Override default tickers
# TICKERS=BTC,ETH,XAUUSD,NVDA