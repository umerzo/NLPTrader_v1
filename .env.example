# Copy this file to ".env" and fill in your real key. Never commit .env to git.
FINNHUB_API_KEY=your_key_here

# How many days back to pull on each run
LOOKBACK_DAYS=3

# --- Primary LLM. Get a FREE Groq key at console.groq.com ---
LLM_API_KEY=your_llm_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- Fallback LLM (used when Groq rate-limits). Get a free key at aistudio.google.com ---
GEMINI_API_KEY=your_gemini_key_here
